<pretext xmlns:xi="http://www.w3.org/2001/XInclude" xml:lang="en-US">
<!-- <pretext xmlns:xi="http://www.w3.org/2001/XInclude" xml:lang="fr-FR"> -->

   
    <book xml:id="numerical-methods">
        <title>Numerical Methods with Programming</title> 

        <xi:include href="./frontmatter.ptx" />                 <!-- Title Page, Preface, etc. -->

        <!-- Parts are optional, included here for testing            -->
        <!-- In "bookinfo.xml" set to "structural" for maximum effect -->

        <part xml:id="part-matlab">
            <title>Using Matlab</title>
            <xi:include href="./matrices_vectors.ptx" /> 
            <xi:include href="./systems_vectorization_plots.ptx" />
            <xi:include href="./functions_input_output.ptx" />
            <xi:include href="./control_flow.ptx" />
            <xi:include href="./user_defined_functions.ptx" />
        </part>

        <part xml:id="part-equations">
            <title>Solving Equations</title>
            <xi:include href="./linear_systems.ptx" />
            <xi:include href="./root_finding_bisection.ptx" />
            <xi:include href="./fixed_point_iteration.ptx" />
            <xi:include href="./newton_secant.ptx" />
            <xi:include href="./multivariable_newton.ptx" />
            <xi:include href="./broyden.ptx" />
        </part>

        <part xml:id="part-calculus">
            <title>Numerical Calculus</title>
            <xi:include href="./numerical_differentiation.ptx" />
            <xi:include href="./trapezoid_midpoint.ptx" />
            <xi:include href="./simpson_newton_cotes.ptx" />
            <xi:include href="./legendre_laguerre.ptx" /> 
            <xi:include href="./gaussian_integration.ptx" /> 
            <xi:include href="./adaptive_integration.ptx" />
            <xi:include href="./multivariable_integration.ptx" />
            <xi:include href="./ode_euler.ptx" />
            <xi:include href="./ode_modeling.ptx" />
        </part>

        <part xml:id="part-data">
            <title>Modeling Data</title>
            <xi:include href="./polynomial_interpolation.ptx" />
            <xi:include href="./chebyshev.ptx" />
            <xi:include href="./spline_interpolation.ptx" />
            <xi:include href="./spline_approximation.ptx" />
            <xi:include href="./discrete_fourier_transform.ptx" />
            <xi:include href="./dft_applications.ptx" />
            <xi:include href="./linear_least_squares.ptx" />
            <xi:include href="./transforming_data.ptx" />
            <xi:include href="./nonlinear_least_squares.ptx" />
        </part>

        <part xml:id="part-optimization">
            <title>Optimization</title> 
            <xi:include href="./single_variable_minimization.ptx" />
            <xi:include href="./parabolic_interpolation_descent.ptx" />
            <xi:include href="./gradient_newton_conjugate.ptx" />
            <xi:include href="./nelder_mead.ptx" />
            <xi:include href="./constrained_optimization.ptx" />
            <xi:include href="./linear_programming.ptx" />
            <xi:include href="./classification.ptx" />
        </part>

    </book>

</pretext>
